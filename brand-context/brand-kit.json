    "memberPrice": {
      "label": "회원가",
      "background": "#eef7ff",
      "foreground": "#0a429e"
    },
    "popular": {
      "label": "인기 숙소",
      "background": "#fffbeb",
      "foreground": "#b45309"
    },
    "dealOfDay": {
      "label": "오늘의 특가",
      "background": "#fff1f2",
      "foreground": "#be123c"
    },
    "freeCancel": {
      "label": "무료 취소 가능",
      "background": "#ecfdf5",
      "foreground": "#047857"
    },
    "payLater": {
      "label": "숙소에서 결제 가능",
      "background": "#eef7ff",
      "foreground": "#0a429e"
    },
    "bookingConfirmed": {
      "label": "예약 확정",
      "background": "#ecfdf5",
      "foreground": "#047857"
    }
  },
  "logo": {
    "full": {
      "assetId": "logo-full",
      "role": "logo_full",
      "colorMode": "fixed"
    },
    "symbol": {
      "assetId": "logo-symbol",
      "role": "logo_symbol",
      "colorMode": "fixed"
    }
