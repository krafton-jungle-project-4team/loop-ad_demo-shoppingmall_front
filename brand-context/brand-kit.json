{
  "schemaVersion": "stayloop.brand_kit.v1",
  "brand": {
    "id": "stayloop",
    "name": "StayLoop",
    "category": "hotel_booking",
    "locale": "ko-KR"
  },
  "color": {
    "loop": {
      "50": "#eef7ff",
      "100": "#d9edff",
      "200": "#b9dcff",
      "500": "#1668e3",
      "600": "#0f55c8",
      "700": "#0a429e",
      "900": "#072b63"
    },
    "ink": {
      "500": "#6b7280",
      "600": "#4b5563",
      "700": "#374151",
      "900": "#111827"
    },
    "surface": {
      "background": "#ffffff",
      "page": "#f8fafc",
      "card": "#ffffff",
      "muted": "#f5f5f5",
      "border": "#e5e7eb"
    },
    "state": {
      "successBg": "#ecfdf5",
      "successText": "#047857",
      "warningBg": "#fffbeb",
      "warningText": "#b45309",
      "promoBg": "#fff1f2",
      "promoText": "#be123c",
      "dangerText": "#e11d48",
      "star": "#f59e0b"
    }
  },
  "typography": {
    "webFontFamily": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
    "emailFontFamily": "-apple-system, \"Apple SD Gothic Neo\", \"Malgun Gothic\", \"Segoe UI\", sans-serif",
    "bodyWeight": 400,
    "labelWeight": 600,
    "headingWeight": 700
